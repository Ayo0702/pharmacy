<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_res_branch_list" model="ir.ui.view">
        <field name="name">res.branch.list</field>
        <field name="model">res.branch</field>
        <field name="arch" type="xml">
            <list string="Branches">
                <field name="name"/>
                <field name="company_id" groups="base.group_multi_company"/>
                <field name="warehouse_id"/>
                <field name="pos_config_id"/>
                <field name="is_active"/>
            </list>
        </field>
    </record>

    <record id="view_res_branch_form" model="ir.ui.view">
        <field name="name">res.branch.form</field>
        <field name="model">res.branch</field>
        <field name="arch" type="xml">
            <form string="Branch">
                <sheet>
                    <div class="oe_title">
                        <label for="name" class="oe_edit_only"/>
                        <h1>
                            <field name="name" placeholder="Branch Name"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="company_id" groups="base.group_multi_company"/>
                            <field name="warehouse_id"/>
                        </group>
                        <group>
                            <field name="pos_config_id"/>
                            <field name="is_active"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_res_branch" model="ir.actions.act_window">
        <field name="name">Branches</field>
        <field name="res_model">res.branch</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first branch!
            </p>
        </field>
    </record>

    <!-- Inherit User's form to add default branch -->
    <record id="view_res_users_form_inherit_branch" model="ir.ui.view">
        <field name="name">res.users.form.inherit.branch</field>
        <field name="model">res.users</field>
        <field name="inherit_id" ref="base.view_users_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='company_id']" position="after">
                <field name="default_branch_id"/>
            </xpath>
        </field>
    </record>
</odoo>
